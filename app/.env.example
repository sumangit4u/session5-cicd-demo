# Copy to .env and fill in, OR point --env-file at ../../../module3_agents/.env,
# which already contains GOOGLE_API_KEY.
#
# The app accepts EITHER of these (GEMINI_API_KEY wins if both are set):
GEMINI_API_KEY=
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Port the app listens on. Cloud platforms usually inject this automatically.
PORT=8000
